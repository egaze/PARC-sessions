<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="robot_name">
    
    <xacro:property name="mass" value="0.1" />
    <xacro:property name="radius" value="0.15" />
    <xacro:property name="length" value="0.12" />

    <xacro:macro name="tyre" params="name parent_link origin rotate axis">

        <!-- The joints for the tyre -->
        <joint name="${name}_joint" type="continuous">
            <origin xyz="${origin}" rpy="${rotate}"/>
            <axis xyz="0 0 ${axis}" />
            <parent link="${parent_link}" />
            <child link="${name}" />
        </joint>


        <link name="${name}">
            <visual name="tyre_visual">
                <origin xyz="0.0 0.0 0.0" />
                <geometry>
                    <cylinder radius="${radius}" length="${length}"/>
                </geometry>
                <material name="black">
                    <color rgba="0.0 0.0 0.0 1.0" />
                </material>
            </visual>

            <collision>
                <origin xyz="0.0 0.0 0.0" />
                <geometry>
                    <cylinder radius="${radius}" length="${length}"/>
                </geometry>
            </collision>

            <inertial>
                <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0" />
                <mass value="${mass}" />
                <inertia 
                    ixx="${(1/12) * mass * (3*radius*radius + length*length)}"
                    iyy="${(1/12) * mass * (3*radius*radius + length*length)}"
                    izz="${(1/2) * mass * (radius*radius)}"
                    ixy="0.0" ixz="0.0" iyz="0.0" />
            </inertial>

        </link>
    </xacro:macro>

    <xacro:macro name="steering_tyre" params="name parent_link origin rotate axis">
        <link name="${name}_steer_link">
            <inertial>
                <mass value="0.01"/>
                <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
            </inertial>
        </link>

        <joint name="${name}_steer_joint" type="revolute">
            <parent link="${parent_link}"/>
            <child link="${name}_steer_link"/>
            <origin xyz="${origin}" rpy="0 0 0"/>
            <axis xyz="0 0 1"/> <limit lower="-0.5" upper="0.5" effort="10.0" velocity="1.0"/>
        </joint>

        <joint name="${name}_joint" type="continuous">
            <origin xyz="0 0 0" rpy="${rotate}"/>
            <axis xyz="0 0 ${axis}" />
            <parent link="${name}_steer_link" />
            <child link="${name}" />
        </joint>

        <link name="${name}">
            <visual>
                <geometry>
                    <cylinder radius="${radius}" length="${length}"/>
                </geometry>
                <material name="black"><color rgba="0 0 0 1"/></material>
            </visual>
            <collision>
                <geometry>
                   <cylinder radius="${radius}" length="${length}"/>
                </geometry>
            </collision>
            <inertial>
                <mass value="0.1" />
                <inertia ixx="0.0001" iyy="0.0001" izz="0.0001" ixy="0" ixz="0" iyz="0" />
            </inertial>
        </link>
    </xacro:macro>
</robot>